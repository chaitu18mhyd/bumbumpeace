# URL of the bumbumpeace-api (Go) service that the site fetches city data from.
# The site calls this SERVER-SIDE, so it is not exposed to the browser.
#
# Local dev (default if unset): http://localhost:8080
# Production (set in Vercel project env vars): your Railway API URL, e.g.
#   https://bumbumpeace-api-production.up.railway.app
API_URL=http://localhost:8080
