    "total_cities": 502,
    "description": "Comprehensive retirement city dataset for Postgres/Supabase import. All scores are 1-10 (10 = best). Monthly costs in USD for a single person, comfortable lifestyle.",
    "schema_notes": {
      "scores": "All *_score fields are 1–10 integers. 10 = best/most favorable for retirees.",
      "monthly_cost": "USD, single person, comfortable lifestyle (not budget, not luxury).",
      "visa_ease_score": "10 = easy long-stay visa or retirement visa available. 1 = very restrictive.",
      "healthcare_score": "10 = world-class private hospitals, low cost. 1 = poor infrastructure.",
      "safety_score": "10 = very safe. 1 = high crime or instability.",
      "climate_score": "10 = year-round pleasant. Subjective — users should filter by climate_type.",
      "expat_community_score": "10 = large established expat/retiree community.",
      "internet_score": "10 = fast, reliable, widely available broadband.",
      "overall_retirement_score": "Weighted composite. Recalculate when user adjusts priority weights."
    },
    "supabase_table_sql": "CREATE TABLE retirement_cities (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), city TEXT NOT NULL, country TEXT NOT NULL, region TEXT NOT NULL, subregion TEXT, latitude FLOAT, longitude FLOAT, monthly_cost_usd INTEGER, lifestyle_label TEXT, description TEXT, tags TEXT[], visa_ease_score INTEGER, healthcare_score INTEGER, safety_score INTEGER, climate_score INTEGER, expat_community_score INTEGER, internet_score INTEGER, overall_retirement_score FLOAT, climate_type TEXT, language TEXT, currency TEXT, time_zone TEXT, popular_neighborhoods TEXT[], visa_notes TEXT, healthcare_notes TEXT, best_for TEXT[], avoid_if TEXT[], expense_shares JSONB, created_at TIMESTAMPTZ DEFAULT NOW());"
  },

